# =============================================================================
# UTI RAG Backend — variables de entorno
# Copia este archivo a `.env` y completa con tus credenciales reales.
# =============================================================================

# --- Supabase --------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# --- Redis (broker Celery + pub/sub de progreso) ---------------------------
REDIS_PASSWORD=cambia_esta_clave
REDIS_URL=redis://:cambia_esta_clave@redis:6379/0

# --- Ollama (LLM) ----------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b
LLM_TEMPERATURE=0.1
LLM_NUM_PREDICT=768

# --- FastAPI ---------------------------------------------------------------
SECRET_KEY=your_secret_key_min_32_chars
ENVIRONMENT=production
ALLOWED_ORIGINS=https://tu-dominio-vercel.vercel.app

# --- Embeddings (BAAI/bge-m3 → vector(1024) en pgvector) -------------------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# auto = usa GPU si torch.cuda disponible, si no CPU
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true

# --- Chunking (HybridChunker de Docling, tokenizer-aware) ------------------
CHUNK_MAX_TOKENS=512
CHUNK_MERGE_PEERS=true

# --- Retrieval (RRF nativo en Postgres) ------------------------------------
RETRIEVAL_TOP_K=5
RETRIEVAL_RRF_K=60
RETRIEVAL_MIN_SIMILARITY=0.4

# --- Ingesta ---------------------------------------------------------------
INDEXER_BATCH_SIZE=100
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=52428800
CELERY_RETRY_MAX=3
CELERY_RETRY_BACKOFF=60

# --- Servidor --------------------------------------------------------------
DOMAIN=tu-ip-o-dominio.com
